#!/bin/sh
APP_ENV=$(grep -E '^APP_ENV=' .env 2>/dev/null | cut -d= -f2 | tr -d '[:space:]')
APP_ENV=${APP_ENV:-development}

if [ "$APP_ENV" = "production" ]; then
    COMPOSE_FILES="-f compose.yaml"
else
    COMPOSE_FILES="-f compose.yaml -f compose.development.yaml"
fi

_dispatch() {
if [ "$1" = "list:commands" ]; then
    cat << 'EOF'
Thryds — ./run command reference

ENVIRONMENT
  env:dev          Switch to development mode and restart containers
  env:prod         Switch to production mode and restart containers
  env:up           Start development containers (preserves .env)
  composer <cmd>   Run any Composer command inside the container (e.g. composer update, composer require …)

CHECK (read-only, safe to run anytime)
  check:all        Run every check and test; JSON summary, never aborts early
  check:composer   Validate composer.json integrity and consistency
  check:style      Verify code style without touching files (dry-run diff)
  check:rector     Verify automated refactor rules without applying them
  check:types      Static analysis — catches type errors before runtime
  check:migrations Confirm migration files are structurally sound
  check:requirements Trace requirements to code; surface uncovered specs
  check:blade-routes     Lint route references inside Blade templates
  check:blade-components Lint component usage inside Blade templates
  check:blade-templates  Lint Blade template structure and syntax
  check:blade-push       Verify @push stacks are consumed by a @stack
  check:coverage   Run full suite with PCOV; emits per-class metrics + clover XML to var/coverage/
                   Pass -- <N> to enforce a minimum line-coverage threshold (e.g. -- 80)

TEST
  test             Run the full test suite (unit + integration + database)
  test:unit        Run unit tests only — fast, no I/O
  test:integration Run integration tests — exercises real app boundaries
  test:database    Run database tests — isolated transactions, real schema
  test:rector      Run tests for custom Rector rules
  test:load        k6 load test against the production build

FIX (modifies files)
  fix:all          Apply all fixes, regenerate preload, then verify with check:all
                   Pass --dry-run (-n) to preview what would be fixed without mutating files
  fix:style        Auto-format all PHP files to project style
  fix:rector       Apply automated refactor rules to the codebase

MIGRATE
  migrate          Apply all pending migrations; emits JSON {"applied":[…],"total":N}
  migrate:status   Display → stderr; JSON {"passed":bool,"pending":[…],"modified":[…],"applied":[…]} → stdout
  migrate:rollback Undo the last migration; emits JSON {"rolled_back":{id,description}|null}

SYNC (derived outputs from current state)
  sync:manifest    Scaffold code for entities in thryds.yaml missing from code
  sync:schema      Create missing tables and sync #[Column] attributes to the live schema
                   Pass -- --dry-run to report drift without modifying anything
  sync:views       Compile Blade templates to bytecode for production
  sync:preload     Regenerate OPcache preload manifest (run before audit:production)

GENERATE (scaffold new files)
  generate:migration    Scaffold a new timestamped migration file
  generate:table        Generate a Table model class from a live database table's schema
  generate:requirement  Scaffold a requirement entry + matching test stub
  generate:rector-rule  Scaffold a new custom Rector rule with tests and docs

DATABASE (read-only)
  db:query         Execute a SELECT statement and print results as JSON
                   Pass -- "<sql>" to specify the query
  list:routes      Print all registered routes as JSON (name, path, dev_only, description, operations)
  list:inventory   Dependency graph: routes→controllers→views→components; JSON (default) or DOT (pass -- --format=dot)

AUDIT (read-only)
  audit:production   Full production readiness checklist (routes, OPcache, templates)
  audit:route-cache  Verify the route cache is valid and up to date
  audit:opcache      Analyse OPcache configuration for production tuning
  audit:profile      Profile live endpoints and report timing (makes HTTP requests)
  audit:hotspots     Parse access logs to surface slow or high-traffic endpoints
EOF

elif [ "$1" = "env:up" ]; then
    docker compose -f compose.yaml -f compose.development.yaml up -d
elif [ "$1" = "env:dev" ]; then
    sed -i '' 's/^APP_ENV=.*/APP_ENV=development/' .env
    docker compose -f compose.yaml -f compose.development.yaml up -d
elif [ "$1" = "env:prod" ]; then
    sed -i '' 's/^APP_ENV=.*/APP_ENV=production/' .env
    docker compose -f compose.yaml up -d
elif [ "$1" = "fix:all" ]; then
    shift
    docker compose $COMPOSE_FILES exec web composer fix:all -- "$@"
elif [ "$1" = "composer" ]; then
    shift
    docker compose $COMPOSE_FILES exec web composer "$@"
elif [ "$1" = "test:load" ]; then
    shift
    docker compose -f compose.load-test.yaml run --rm k6 "$@"
else
    docker compose $COMPOSE_FILES exec web composer "$@"
fi
}

_LOG_DIR="logs/run"
mkdir -p "$_LOG_DIR"
_TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
_START=$(date +%s)
_CMD="${1:-}"

_dispatch "$@"
_EXIT=$?

_END=$(date +%s)
_S=$((_END - _START))

# Build a JSON array from args beyond the command
_ARGS_JSON="["
_i=0
for _a in "$@"; do
    _i=$((_i + 1))
    [ $_i -eq 1 ] && continue
    [ "$_ARGS_JSON" != "[" ] && _ARGS_JSON="${_ARGS_JSON},"
    _ARGS_JSON="${_ARGS_JSON}\"$(printf '%s' "$_a" | sed 's/\\/\\\\/g; s/"/\\"/g')\""
done
_ARGS_JSON="${_ARGS_JSON}]"

printf '{"ts":"%s","cmd":"%s","args":%s,"env":"%s","exit":%d,"s":%d}\n' \
    "$_TS" "$_CMD" "$_ARGS_JSON" "$APP_ENV" "$_EXIT" "$_S" \
    >> "$_LOG_DIR/$(date +%Y-%m-%d).jsonl"

exit $_EXIT
