{
    "name": "zero-to-prod/thryds",
    "description": "An AI integrated social media site.",
    "type": "project",
    "require": {
        "php": "^8.5",
        "league/route": "^6.2",
        "laminas/laminas-diactoros": "^3.8",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "jenssegers/blade": "^2",
        "zero-to-prod/data-model": "^81.14",
        "ext-frankenphp": "*",
        "ext-zend-opcache": "*"
    },
    "autoload": {
        "psr-4": {
            "ZeroToProd\\Thryds\\": "src/"
        },
        "files": [
            "src/Helpers/function.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ZeroToProd\\Thryds\\Tests\\": "tests/",
            "Utils\\Rector\\Rector\\": "utils/rector/src/",
            "Utils\\Rector\\Tests\\": "utils/rector/tests/"
        }
    },
    "authors": [
        {
            "name": "David Smith",
            "email": "dasmith@zero-to-prod.com"
        }
    ],
    "require-dev": {
        "rector/rector": "^2.3",
        "phpunit/phpunit": "^13.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "platform": {
            "ext-frankenphp": "1.0",
            "ext-zend-opcache": "1.0"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test:unit": "./vendor/bin/phpunit --testsuite unit",
        "test:integration": "./vendor/bin/phpunit --testsuite integration",
        "test:rector": "./vendor/bin/phpunit utils",
        "lint": "./vendor/bin/php-cs-fixer fix",
        "lint:check": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
        "rector": "./vendor/bin/rector process",
        "rector:check": "./vendor/bin/rector process --dry-run",
        "phpstan": "./vendor/bin/phpstan analyse",
        "opcache": "php scripts/opcache-audit.php",
        "preload:generate": "php scripts/generate-preload.php",
        "route-cache:verify": "php scripts/verify-route-cache.php",
        "lint:blade-routes": "php scripts/lint-blade-routes.php",
        "lint:all": [
            "@lint",
            "@rector",
            "@phpstan",
            "@lint:blade-routes",
            "@test"
        ],
        "production:checklist": "php scripts/production-checklist.php"
    }
}
